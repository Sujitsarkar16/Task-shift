MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="taskshift"
API_PORT="4000"
# Optional: override API base URL for the client (defaults to /api on same origin).
NEXT_PUBLIC_API_BASE_URL="/api"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Auth.js session encryption — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Must match the URL in your browser (use localhost, not 127.0.0.1)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
